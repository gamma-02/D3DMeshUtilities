<Window x:Class="D3DMeshUtilities.ArchiveModelList"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:local="clr-namespace:D3DMeshUtilities"
        mc:Ignorable="d"
        Title="ArchiveModelList" Height="450" Width="800"
        WindowStartupLocation="CenterOwner">
    <Grid>
        <Grid.Resources>
            <Style TargetType="{x:Type Grid}">
                <Setter Property="Margin" Value="10 10"/>
            </Style>
        </Grid.Resources>
        
        <Grid.RowDefinitions>
            <RowDefinition Height="50"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"></RowDefinition>
        </Grid.RowDefinitions>
        
        <TextBlock VerticalAlignment="Center" HorizontalAlignment="Center" FontSize="24"> Select Mesh To Export </TextBlock>
        
        <Grid Grid.Row="1" Background="LightGray">
            <ListView Name="ModelList" SelectionChanged="ModelList_SelectionChanged" >
                <ListViewItem>
                    <TextBlock HorizontalAlignment="Center" FontStretch="Expanded"> Loading... </TextBlock>
                </ListViewItem>
            </ListView>
        </Grid>
        
        <Grid Row="2" Visibility="Collapsed" Name="ConvertButtonGrid">
            <Button FontSize="16" Click="BeginConversion"> Choose output directories >>></Button>
        </Grid>
    </Grid>
</Window>
