<Project Sdk="Microsoft.NET.Sdk">

    <PropertyGroup>
        <OutputType>WinExe</OutputType>
        <TargetFramework>net9.0-windows</TargetFramework>
<!--        <RuntimeIdentifiers>win-x64</RuntimeIdentifiers>-->
        <RuntimeIdentifier>win-x64</RuntimeIdentifier>
        <Nullable>enable</Nullable>
        <ImplicitUsings>enable</ImplicitUsings>
        <UseWPF>true</UseWPF>
        <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
        <LangVersion>14</LangVersion>
    </PropertyGroup>

    <ItemGroup>
      <Folder Include="bin\Debug\net9.0-windows\" />
      <Folder Include="Resources\" />
    </ItemGroup>

    <ItemGroup>
      <!-- Exclude all .cs files in a specific directory -->
      <Compile Remove="ExFromShadow\*.cs" />
    </ItemGroup>

    <ItemGroup>
      <PackageReference Include="DrSwizzler" Version="1.1.1" />
      <PackageReference Include="Hexa.NET.DirectXTex" Version="2.0.4" />
      <PackageReference Include="Hexa.NET.ImGui" Version="2.2.10-prerelease" />
      <PackageReference Include="LuaCSharp" Version="0.5.3" />
      <PackageReference Include="SharpGLTF.Core" Version="1.0.6" />
      <PackageReference Include="SharpGLTF.Toolkit" Version="1.0.6" />
    </ItemGroup>


    <ItemGroup>
      <ProjectReference Include="..\TelltaleToolKit-Contribs\src\TelltaleToolKit\TelltaleToolKit.csproj" />
    </ItemGroup>
  
  
    <Target Name="CopyOverDataBuild" AfterTargets="AfterBuild"><!-- BeforeTargets="Publish">-->
      
      <Message Text="Copied data directory!" Importance="high"/>
      <Message Text="MSBuild dir: $(MSBuildProjectDirectory)" Importance="high"/>
      <Message Text="Target dir: $(TargetDir)"/>
      <Message Text="Output Path: $(OutputPath)" Importance="high"/>
      
      <ItemGroup>
        <SourceFiles Include="$(MSBuildProjectDirectory)\..\TelltaleToolKit-Contribs\data/**/*.*" />        
      </ItemGroup>

      <Copy
            SourceFiles="@(SourceFiles)"
            DestinationFolder="$(TargetDir)data/%(RecursiveDir)"
            SkipUnchangedFiles="False"
      />
      
    </Target>

    <Target Name="CopyOverData" AfterTargets="Publish">
  
      <Message Text="Copied data directory into publish directory!" Importance="high"/>
      <Message Text="MSBuild dir: $(MSBuildProjectDirectory)"/>
      <Message Text="Publish dir: $(PublishDir)" Importance="high"/>
  
      <ItemGroup>
        <SourceFiles Include="$(MSBuildProjectDirectory)\..\TelltaleToolKit-Contribs\data/**/*.*" />
      </ItemGroup>
  
      <Copy
              SourceFiles="@(SourceFiles)"
              DestinationFolder="$(PublishDir)data/%(RecursiveDir)"
              SkipUnchangedFiles="False"
      />
  
    </Target>
    
</Project>
