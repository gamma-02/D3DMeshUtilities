<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Design.PreviewWith>
        <Border Padding="20">
            <!-- Add Controls for Previewer Here -->
        </Border>
    </Design.PreviewWith>

    <!-- Add Styles Here -->
    <Styles.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceInclude Source="SubListsStuff/Expander.axaml"></ResourceInclude>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Styles.Resources>
    
    <Style Selector="Control.comingSoon">
        <Setter Property="ToolTip.Tip">
            <Template>
                <Border CornerRadius="4" Padding="8" Background="{DynamicResource ThemeBackgroundColor}" BorderThickness="1">
                    <StackPanel Spacing="4">
                        <TextBlock Text="Feature coming soon!"/>
                    </StackPanel>
                </Border>
            </Template>
        </Setter>
        <Setter Property="ToolTip.ShowOnDisabled" Value="True" />
    </Style>
    
    <!-- <Style Selector="Expander.test-thing"> -->
    <!--     <Setter Property="Theme" Value="{StaticResource }"></Setter> -->
    <!-- </Style> -->
</Styles>
