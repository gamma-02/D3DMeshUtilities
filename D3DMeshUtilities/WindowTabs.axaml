<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="D3DMeshUtilities.WindowTabs">
    <TabControl Height="28" VerticalAlignment="Top" Name="Header">
        <TabItem Header="Load Resources" FontSize="16" />
        <TabItem FontSize="16">
            <TabItem.Header>
                <ComboBox 
                    Name="IntermediateDropdown" 
                    ZIndex="1" 
                    FontSize="16" 
                    SelectionChanged="IntermediateDropdown_OnSelectionChanged" 
                    DropDownClosed="IntermediateDropdown_OnDropDownClosed"
                    DropDownOpened="IntermediateDropdown_OnDropDownOpened"
                    >
                    
                </ComboBox>
            </TabItem.Header>
        </TabItem>
        <TabItem Header="Convert Models" FontSize="16" />
    </TabControl>
</UserControl>
